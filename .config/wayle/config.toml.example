left-click = ""
right-click = ""
middle-click = ""
scroll-up = ""
scroll-down = ""
thresholds = []

[modules.separator]
size = 1
length = 1.5
color = "fg-subtle"

[modules.systray]
icon-scale = 1.0
item-gap = 0.25
internal-padding = 0.5
blacklist = []
overrides = []
border-show = false
border-color = "border-accent"
button-bg-color = "bg-surface-elevated"

[modules.volume]
level-icons = [
    "ld-volume-symbolic",
    "ld-volume-1-symbolic",
    "ld-volume-2-symbolic",
]
icon-muted = "ld-volume-x-symbolic"
border-show = false
border-color = "red"
icon-show = true
icon-color = "auto"
icon-bg-color = "red"
label-show = true
label-color = "red"
