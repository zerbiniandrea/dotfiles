button-bg-color = "bg-surface-elevated"
left-click = "dropdown:audio"
right-click = ""
middle-click = "wayle audio output-mute"
scroll-up = ""
scroll-down = ""
dropdown-app-icons = "mapped"
thresholds = []

[modules.weather]
provider = "open-meteo"
location = "San Francisco"
units = "metric"
format = "{{ temp }}{{ temp_unit }}"
time-format = "12h"
refresh-interval-seconds = 1800
icon-name = "ld-sun-symbolic"
border-show = false
border-color = "border-accent"
icon-show = true
icon-color = "auto"
icon-bg-color = "accent"
label-show = true
label-color = "accent"
label-max-length = 0
button-bg-color = "bg-surface-elevated"
left-click = "dropdown:weather"
right-click = ""
middle-click = ""
scroll-up = ""
scroll-down = ""

[modules.window-title]
format = "{{ title }}"
icon-name = "ld-app-window-symbolic"
border-show = false
border-color = "blue"
icon-show = true
icon-color = "auto"
icon-bg-color = "blue"
label-show = true
label-color = "blue"
label-max-length = 50
button-bg-color = "bg-surface-elevated"
left-click = ""
right-click = ""
