mount-point = "/"
format = "{{ percent }}%"
icon-name = "ld-hard-drive-symbolic"
border-show = false
border-color = "yellow"
icon-show = true
icon-color = "auto"
icon-bg-color = "yellow"
label-show = true
label-color = "yellow"
label-max-length = 0
